<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="top|center_horizontal"
    android:orientation="vertical">

        <!-- Subscription Timer Card moved to top -->
     <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="#1A1A1A">

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="3dp">

     <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:fontFamily="@font/raleway_bold"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        android:text="Your Subscription Time Will Be End On" />

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Days Unit -->
     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_uuid">

     <TextView
        android:id="@+id/tv_d"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="00"
        android:textSize="24sp"
        android:fontFamily="@font/font1"
        android:textColor="#FFFFFF" />

     <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Day"
        android:textSize="14sp"
        android:fontFamily="@font/font1"
        android:textAllCaps="true"
        android:textColor="#FFFFFF" />

     </LinearLayout>

     <!-- Separator -->
     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=":"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

        <!-- Hours Unit -->
     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_uuid">

     <TextView
        android:id="@+id/tv_h"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="00"
        android:textSize="24sp"
        android:fontFamily="@font/font1"
        android:textColor="#FFFFFF" />

     <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Hours"
        android:textSize="14sp"
        android:fontFamily="@font/font1"
        android:textAllCaps="true"
        android:textColor="#FFFFFF" />

     </LinearLayout>

        <!-- Separator -->
     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=":"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

        <!-- Minutes Unit -->
     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_uuid">

     <TextView
        android:id="@+id/tv_m"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="00"
        android:textSize="24sp"
        android:fontFamily="@font/font1"
        android:textColor="#FFFFFF" />

     <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Minute"
        android:textSize="14sp"
        android:fontFamily="@font/font1"
        android:textAllCaps="true"
        android:textColor="#FFFFFF" />

     </LinearLayout>

        <!-- Separator -->
     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=":"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

        <!-- Seconds Unit -->
     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_uuid">

     <TextView
        android:id="@+id/tv_s"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="00"
        android:textSize="24sp"
        android:fontFamily="@font/font1"
        android:textColor="#FFFFFF" />

     <TextView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Second"
        android:textSize="14sp"
        android:fontFamily="@font/font1"
        android:textAllCaps="true"
        android:textColor="#FFFFFF" />

     </LinearLayout>

     </LinearLayout>
     </LinearLayout>
     </androidx.cardview.widget.CardView>

        <!-- Original TextView and rest of layout -->
     <TextView
        android:id="@+id/textview21"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:paddingRight="5dp"
        android:paddingBottom="8dp"
        android:fontFamily="@font/bold"
        android:text=""
        android:textSize="13sp"
        android:textColor="#FFFFFF" />

        <!-- Play Info Card -->
     <androidx.cardview.widget.CardView
        android:id="@+id/card_play_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/black2"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

     <ImageView
        android:id="@+id/myIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/pubg_india"
        android:layout_marginEnd="12dp" />

     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

     <TextView
        android:id="@+id/Enc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Battle Ground Mobile India"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:fontFamily="@font/bold"
        android:layout_marginBottom="4dp" />

     <TextView
        android:id="@+id/gameVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Version : 3.8"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:fontFamily="@font/calibri" />

     <TextView
        android:id="@+id/gameContainerStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status : Safe"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:fontFamily="@font/calibri" />

     </LinearLayout>
     </LinearLayout>

     <Button
        android:id="@+id/starthack"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/rounded_button"
        android:text="PLAY GAME"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:fontFamily="@font/calibri"
        android:gravity="center" />

     </LinearLayout>
     </androidx.cardview.widget.CardView>

        <!-- Progress Bar -->
     <ProgressBar
        android:id="@+id/obb_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        android:max="100"
        style="?android:attr/progressBarStyleHorizontal"
        android:progress="0" />

    <!-- Social Icons -->
     <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:cardBackgroundColor="@color/black2"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Login Support Text -->
     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Login Support"
        android:textColor="@android:color/white"
        android:fontFamily="@font/bold"
        android:textSize="16sp"
        android:layout_marginBottom="8dp" />

        <!-- Social Icons Row -->
     <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

     <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/btn_twitter"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/twitter" />

     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Twitter"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>
     </LinearLayout>

     <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

     <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/btn_via_browser"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/facebook" />

     <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Facebook"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:layout_marginTop="4dp"/>
     </LinearLayout>

     </LinearLayout>
     </LinearLayout>
     </androidx.cardview.widget.CardView>
</LinearLayout>
